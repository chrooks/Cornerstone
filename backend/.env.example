# Copy this file to .env and fill in your values
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Required for require_admin JWT verification: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Comma-separated list of allowed frontend origins for CORS.
# Defaults to http://localhost:3000 in development.
# Set to your production domain in production (e.g. https://cornerstone.example.com).
FRONTEND_ORIGIN=http://localhost:3000

ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional — defaults to claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514
